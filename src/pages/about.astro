---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="About">

  <!-- Intro -->
  <section class="pt-32 pb-14 bg-gradient-to-b from-sage-50 to-white dark:from-stone-950 dark:to-stone-900">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
      <div>
        <p class="text-sage-600 dark:text-sage-400 font-medium text-sm tracking-widest uppercase mb-4">About Me</p>
        <h1 class="font-heading text-5xl md:text-6xl font-bold text-stone-900 dark:text-white leading-tight">
          Hi, I'm Nancy Chiuri
        </h1>
        <p class="mt-6 text-lg text-stone-500 dark:text-stone-400 leading-relaxed">
          A mother of six and wellness advocate passionate about helping mothers live healthy, confident lives.
        </p>
        <p class="mt-4 text-lg text-stone-500 dark:text-stone-400 leading-relaxed">
          I believe every mother deserves to feel strong in her body, clear in her mind, and grounded in her spirit — no matter how busy life gets.
        </p>
      </div>

      <div class="aspect-[4/5] rounded-3xl bg-gradient-to-br from-sage-200 to-earth-200 dark:from-sage-800 dark:to-earth-800 flex items-center justify-center text-stone-400 dark:text-stone-500">
        <div class="text-center">
          <svg class="w-16 h-16 mx-auto mb-4 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="text-sm">Professional lifestyle portrait</p>
        </div>
      </div>
    </div>
  </section>

  <!-- My Story -->
  <section class="py-14 bg-white dark:bg-stone-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mx-auto">
        <p class="text-sage-600 dark:text-sage-400 font-medium text-sm tracking-widest uppercase mb-4">My Story</p>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-stone-900 dark:text-white leading-tight">
          Six Pregnancies. One Transformation.
        </h2>

        <div class="mt-10 space-y-6 text-lg text-stone-500 dark:text-stone-400 leading-relaxed">
          <p>
            Through six pregnancies, I experienced the full spectrum of what motherhood does to your body. I gained weight, lost it, gained it again — each time wondering if I'd ever feel like myself.
          </p>
          <p>
            But somewhere along the way, I stopped chasing "before" and started building something new. Through consistency, faith, and practical fitness, I didn't just transform my body — I transformed my relationship with it.
          </p>
          <p>
            That journey taught me something powerful: wellness isn't about perfection or punishment. It's about showing up for yourself with grace, even on the hard days. Especially on the hard days.
          </p>
          <p>
            Now I pour everything I've learned into helping other mothers find that same strength — through coaching, community, and experiences that remind us we matter too.
          </p>
        </div>
      </div>

      <!-- Story Images -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-16 max-w-4xl mx-auto">
        <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-warm-100 to-warm-200 dark:from-warm-900 dark:to-warm-800 flex items-center justify-center text-stone-400 dark:text-stone-500">
          <div class="text-center">
            <svg class="w-10 h-10 mx-auto mb-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm">Family lifestyle image</p>
          </div>
        </div>
        <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-sage-100 to-sage-200 dark:from-sage-900 dark:to-sage-800 flex items-center justify-center text-stone-400 dark:text-stone-500">
          <div class="text-center">
            <svg class="w-10 h-10 mx-auto mb-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm">Fitness moments</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact -->
  <section class="py-14 bg-stone-100 dark:bg-stone-950">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <p class="text-sage-600 dark:text-sage-400 font-medium text-sm tracking-widest uppercase mb-4">Impact</p>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-stone-900 dark:text-white leading-tight">
          Making a Difference
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white dark:bg-stone-800 p-8 rounded-2xl">
          <div class="w-14 h-14 rounded-2xl bg-sage-100 dark:bg-sage-900 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-sage-700 dark:text-sage-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-stone-900 dark:text-white mb-3">Fitness & Mental Health Events</h3>
          <p class="text-stone-500 dark:text-stone-400 leading-relaxed">Organizing community events that combine physical fitness with mental wellness support for mothers.</p>
        </div>

        <div class="bg-white dark:bg-stone-800 p-8 rounded-2xl">
          <div class="w-14 h-14 rounded-2xl bg-warm-100 dark:bg-warm-900 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-warm-700 dark:text-warm-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-stone-900 dark:text-white mb-3">Prison Wellness Program</h3>
          <p class="text-stone-500 dark:text-stone-400 leading-relaxed">Bringing fitness and wellness programs to women in correctional facilities, supporting rehabilitation through movement.</p>
        </div>

        <div class="bg-white dark:bg-stone-800 p-8 rounded-2xl">
          <div class="w-14 h-14 rounded-2xl bg-earth-100 dark:bg-earth-900 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-earth-700 dark:text-earth-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-stone-900 dark:text-white mb-3">Online Sessions</h3>
          <p class="text-stone-500 dark:text-stone-400 leading-relaxed">Virtual coaching and workout sessions that reach mothers wherever they are, making wellness accessible to all.</p>
        </div>
      </div>

      <!-- Impact Images -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
        <div class="aspect-video rounded-2xl bg-gradient-to-br from-earth-100 to-earth-200 dark:from-earth-900 dark:to-earth-800 flex items-center justify-center text-stone-400 dark:text-stone-500">
          <div class="text-center">
            <svg class="w-10 h-10 mx-auto mb-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm">Event photos</p>
          </div>
        </div>
        <div class="aspect-video rounded-2xl bg-gradient-to-br from-sage-100 to-sage-200 dark:from-sage-900 dark:to-sage-800 flex items-center justify-center text-stone-400 dark:text-stone-500">
          <div class="text-center">
            <svg class="w-10 h-10 mx-auto mb-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm">Speaking engagements</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 bg-sage-700 dark:bg-sage-900 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-sage-600 dark:bg-sage-800 rounded-full -translate-y-1/2 translate-x-1/2 opacity-50"></div>
    <div class="max-w-3xl mx-auto px-6 text-center relative z-10">
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-white leading-tight">
        Ready to start your journey?
      </h2>
      <p class="mt-6 text-lg text-sage-200 dark:text-sage-300 leading-relaxed">
        Whether you're postpartum, mid-transformation, or just getting started — there's a place for you here.
      </p>
      <a
        href="/services"
        class="inline-block mt-10 px-10 py-4 bg-white text-sage-700 font-semibold rounded-full hover:bg-stone-100 transition-colors"
      >
        Work With Me
      </a>
    </div>
  </section>

</MainLayout>
