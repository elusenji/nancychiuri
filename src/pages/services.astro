---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Work With Me">

  <!-- Header -->
  <section class="pt-28 pb-10 bg-gradient-to-b from-warm-50 to-white dark:from-stone-950 dark:to-stone-900">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-sage-600 dark:text-sage-400 font-medium text-sm tracking-widest uppercase mb-4">Work With Me</p>
      <h1 class="font-heading text-5xl md:text-6xl font-bold text-stone-900 dark:text-white leading-tight">
        Let's Build Your Wellness Together
      </h1>
      <p class="mt-4 text-lg text-stone-500 dark:text-stone-400 leading-relaxed">
        From one-on-one coaching to group retreats, find the path that fits your life.
      </p>
    </div>
  </section>

  <!-- Fitness Coaching -->
  <section class="py-14 bg-white dark:bg-stone-900">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
      <div class="aspect-[4/3] rounded-3xl bg-gradient-to-br from-sage-100 to-sage-200 dark:from-sage-900 dark:to-sage-800 flex items-center justify-center text-stone-400 dark:text-stone-500 order-2 lg:order-1">
        <div class="text-center">
          <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="text-sm">Group workouts</p>
        </div>
      </div>

      <div class="order-1 lg:order-2">
        <div class="w-12 h-12 rounded-xl bg-sage-100 dark:bg-sage-900 flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-sage-700 dark:text-sage-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </div>
        <h2 class="font-heading text-3xl font-bold text-stone-900 dark:text-white leading-tight">Fitness Coaching</h2>
        <p class="mt-3 text-lg text-stone-500 dark:text-stone-400 leading-relaxed">
          Personalized fitness support designed around your life as a mother.
        </p>
        <ul class="mt-4 space-y-2">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-sage-600 dark:text-sage-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-stone-600 dark:text-stone-300">Postpartum recovery programs</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-sage-600 dark:text-sage-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-stone-600 dark:text-stone-300">Home workouts that fit your schedule</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-sage-600 dark:text-sage-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-stone-600 dark:text-stone-300">Sustainable weight management guidance</span>
          </li>
        </ul>
        <a href="/programs" class="inline-block mt-6 px-8 py-3.5 bg-sage-600 text-white font-medium rounded-full hover:bg-sage-700 transition-colors">
          Join a Program
        </a>
      </div>
    </div>
  </section>

  <!-- Events & Speaking -->
  <section class="py-14 bg-stone-100 dark:bg-stone-950">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
      <div>
        <div class="w-12 h-12 rounded-xl bg-warm-100 dark:bg-warm-900 flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-warm-700 dark:text-warm-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
          </svg>
        </div>
        <h2 class="font-heading text-3xl font-bold text-stone-900 dark:text-white leading-tight">Events & Speaking</h2>
        <p class="mt-3 text-lg text-stone-500 dark:text-stone-400 leading-relaxed">
          Inspiring talks, interactive panels, and hands-on workshops on maternal wellness, fitness, and empowerment.
        </p>
        <ul class="mt-4 space-y-2">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-warm-600 dark:text-warm-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-stone-600 dark:text-stone-300">Keynote talks and panel discussions</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-warm-600 dark:text-warm-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-stone-600 dark:text-stone-300">Wellness workshops for organizations</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-warm-600 dark:text-warm-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-stone-600 dark:text-stone-300">Community fitness and mental health events</span>
          </li>
        </ul>
        <a href="/contact" class="inline-block mt-6 px-8 py-3.5 bg-warm-600 text-white font-medium rounded-full hover:bg-warm-700 transition-colors">
          Book Me
        </a>
      </div>

      <div class="aspect-[4/3] rounded-3xl bg-gradient-to-br from-warm-100 to-warm-200 dark:from-warm-900 dark:to-warm-800 flex items-center justify-center text-stone-400 dark:text-stone-500">
        <div class="text-center">
          <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="text-sm">Event speaking</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wellness Trips -->
  <section class="py-14 bg-white dark:bg-stone-900">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
      <div class="aspect-[4/3] rounded-3xl bg-gradient-to-br from-earth-100 to-sage-200 dark:from-earth-900 dark:to-sage-800 flex items-center justify-center text-stone-400 dark:text-stone-500 order-2 lg:order-1">
        <div class="text-center">
          <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="text-sm">Hiking trips</p>
        </div>
      </div>

      <div class="order-1 lg:order-2">
        <div class="w-12 h-12 rounded-xl bg-earth-100 dark:bg-earth-900 flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-earth-700 dark:text-earth-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 class="font-heading text-3xl font-bold text-stone-900 dark:text-white leading-tight">Wellness Trips</h2>
        <p class="mt-3 text-lg text-stone-500 dark:text-stone-400 leading-relaxed">
          Step away from the routine and reconnect with yourself through movement in nature.
        </p>
        <ul class="mt-4 space-y-2">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-earth-600 dark:text-earth-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-stone-600 dark:text-stone-300">Guided hiking adventures</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-earth-600 dark:text-earth-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-stone-600 dark:text-stone-300">Community walking groups</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-earth-600 dark:text-earth-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-stone-600 dark:text-stone-300">Nature retreats for rest and renewal</span>
          </li>
        </ul>
        <a href="/contact" class="inline-block mt-6 px-8 py-3.5 bg-earth-600 text-white font-medium rounded-full hover:bg-earth-700 transition-colors">
          Join a Retreat
        </a>
      </div>
    </div>
  </section>

</MainLayout>
