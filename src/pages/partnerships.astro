---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Brand Partnerships">

  <!-- Header -->
  <section class="pt-32 pb-16 bg-gradient-to-b from-earth-50 to-white dark:from-stone-950 dark:to-stone-900">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-sage-600 dark:text-sage-400 font-medium text-sm tracking-widest uppercase mb-4">Partnerships</p>
      <h1 class="font-heading text-5xl md:text-6xl font-bold text-stone-900 dark:text-white leading-tight">
        Let's Collaborate
      </h1>
      <p class="mt-6 text-lg text-stone-500 dark:text-stone-400 leading-relaxed">
        Partner with a trusted voice in maternal fitness and wellness to reach an engaged community of mothers.
      </p>
    </div>
  </section>

  <!-- Audience & Value -->
  <section class="py-14 bg-white dark:bg-stone-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Audience -->
        <div class="p-10 rounded-3xl bg-sage-50 dark:bg-stone-800 border border-sage-100 dark:border-stone-700 text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-sage-200 dark:bg-sage-800 flex items-center justify-center">
            <svg class="w-8 h-8 text-sage-700 dark:text-sage-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-stone-900 dark:text-white mb-3">My Audience</h3>
          <p class="text-stone-500 dark:text-stone-400 leading-relaxed">Women and mothers who are passionate about wellness, fitness, and living a balanced, healthy life.</p>
        </div>

        <!-- Reach -->
        <div class="p-10 rounded-3xl bg-warm-50 dark:bg-stone-800 border border-warm-100 dark:border-stone-700 text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-warm-200 dark:bg-warm-800 flex items-center justify-center">
            <svg class="w-8 h-8 text-warm-700 dark:text-warm-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-stone-900 dark:text-white mb-3">My Reach</h3>
          <div class="space-y-2 mt-4">
            <div class="flex justify-between items-center px-4">
              <span class="text-stone-600 dark:text-stone-400 text-sm">Instagram</span>
              <span class="font-heading font-bold text-stone-900 dark:text-white">10.2K</span>
            </div>
            <div class="flex justify-between items-center px-4">
              <span class="text-stone-600 dark:text-stone-400 text-sm">Facebook</span>
              <span class="font-heading font-bold text-stone-900 dark:text-white">13K</span>
            </div>
          </div>
        </div>

        <!-- Value -->
        <div class="p-10 rounded-3xl bg-earth-50 dark:bg-stone-800 border border-earth-100 dark:border-stone-700 text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-earth-200 dark:bg-earth-800 flex items-center justify-center">
            <svg class="w-8 h-8 text-earth-700 dark:text-earth-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-stone-900 dark:text-white mb-3">My Value</h3>
          <p class="text-stone-500 dark:text-stone-400 leading-relaxed">Authentic storytelling, high engagement, and a deep trust with my community built over years of real, relatable content.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What I Offer -->
  <section class="py-14 bg-stone-100 dark:bg-stone-950">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-heading text-4xl font-bold text-stone-900 dark:text-white text-center mb-8">Partnership Types</h2>
      <div class="space-y-6">
        <div class="bg-white dark:bg-stone-800 p-8 rounded-2xl flex items-start gap-6">
          <div class="w-12 h-12 rounded-xl bg-sage-100 dark:bg-sage-900 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-sage-700 dark:text-sage-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-lg text-stone-900 dark:text-white">Sponsored Content</h3>
            <p class="mt-2 text-stone-500 dark:text-stone-400 leading-relaxed">Authentic posts, stories, and reels featuring your product woven naturally into my fitness and wellness content.</p>
          </div>
        </div>

        <div class="bg-white dark:bg-stone-800 p-8 rounded-2xl flex items-start gap-6">
          <div class="w-12 h-12 rounded-xl bg-warm-100 dark:bg-warm-900 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-warm-700 dark:text-warm-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-lg text-stone-900 dark:text-white">Event Partnerships</h3>
            <p class="mt-2 text-stone-500 dark:text-stone-400 leading-relaxed">Co-branded wellness events, workshops, and retreats that put your brand in front of an engaged audience.</p>
          </div>
        </div>

        <div class="bg-white dark:bg-stone-800 p-8 rounded-2xl flex items-start gap-6">
          <div class="w-12 h-12 rounded-xl bg-earth-100 dark:bg-earth-900 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-earth-700 dark:text-earth-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-lg text-stone-900 dark:text-white">Brand Ambassadorship</h3>
            <p class="mt-2 text-stone-500 dark:text-stone-400 leading-relaxed">Long-term partnerships where I become a genuine advocate for your brand within the maternal wellness space.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 bg-sage-700 dark:bg-sage-900 relative overflow-hidden">
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-sage-800 dark:bg-sage-950 rounded-full translate-y-1/2 -translate-x-1/2 opacity-50"></div>
    <div class="max-w-3xl mx-auto px-6 text-center relative z-10">
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-white leading-tight">
        Ready to partner?
      </h2>
      <p class="mt-6 text-lg text-sage-200 dark:text-sage-300 leading-relaxed">
        Let's create something meaningful together. Reach out to discuss collaboration opportunities.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-10">
        <a
          href="/contact"
          class="px-10 py-4 bg-white text-sage-700 font-semibold rounded-full hover:bg-stone-100 transition-colors"
        >
          Contact for Collaborations
        </a>
        <a
          href="#"
          class="px-10 py-4 border-2 border-white/30 text-white font-semibold rounded-full hover:border-white/60 transition-colors"
        >
          Download Rate Card
        </a>
      </div>
    </div>
  </section>

</MainLayout>
